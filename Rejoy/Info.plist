<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>CFBundleIconName</key>
	<string>AppIcon</string>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>AccentColor</string>
	</dict>
	<key>NSHealthShareUsageDescription</key>
	<string>Rejoy uses health data to track workouts, steps, exercise time, mindful sessions, and sleep for your daily dedication summary.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>Rejoy may save dedication data to Health.</string>
	<key>NSMotionUsageDescription</key>
	<string>Rejoy uses motion data to estimate walking and running time for your daily summary.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Rejoy uses location to estimate time spent at your saved places (e.g. Home, Temple).</string>
	<key>NSCalendarsFullAccessUsageDescription</key>
	<string>Rejoy reads calendar events to include meeting and event time in your daily dedication summary.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Rejoy saves your activity stickers to your photo library when you tap Save.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>ReJ uses the microphone to record voice dedications for your practice sessions.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>ReJ uses speech recognition to transcribe your dedication when you save a session.</string>
	<key>UIRequiresFullScreen</key>
	<true/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
	</array>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.globio.rejoy</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>rejoy</string>
			</array>
			<key>CFBundleRoleEditor</key>
			<string>Viewer</string>
		</dict>
	</array>
</dict>
</plist>
